# ================================================================
# MyCosmetics Production Environment Template
# COPY to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.
# Use Docker secrets or a vault (HashiCorp Vault, AWS Secrets Manager)
# for production — this file is for documentation only.
# ================================================================

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=mycosmetics
POSTGRES_USER=mycosmetics
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD_MIN_32_CHARS

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD_MIN_32_CHARS

# ── Serverpod ───────────────────────────────────────────────────
SERVERPOD_DATABASE_HOST=postgres
SERVERPOD_DATABASE_NAME=mycosmetics
SERVERPOD_DATABASE_USER=mycosmetics
SERVERPOD_DATABASE_PASS=SAME_AS_POSTGRES_PASSWORD
SERVERPOD_REDIS_HOST=redis
SERVERPOD_REDIS_PASSWORD=SAME_AS_REDIS_PASSWORD
# 64+ random bytes, base64 encoded
SERVERPOD_SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_64

# ── Stripe ──────────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ── Cloud Storage (AWS S3 or GCS) ────────────────────────────────
CLOUD_STORAGE_BUCKET=mycosmetics-assets-prod
CLOUD_STORAGE_KEY_ID=CHANGE_ME
CLOUD_STORAGE_SECRET=CHANGE_ME
CLOUD_STORAGE_REGION=me-south-1

# ── Firebase Cloud Messaging ─────────────────────────────────────
FCM_SERVER_KEY=CHANGE_ME

# ── Email (for password reset) ───────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
EMAIL_FROM=noreply@mycosmetics.app

# ── Monitoring ───────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME
SLACK_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME

# ── Backup ───────────────────────────────────────────────────────
BACKUP_BUCKET=mycosmetics-backups-prod

# ── Deployment ───────────────────────────────────────────────────
PROD_HOST=your.production.server.ip
PROD_USER=deploy
STAGING_HOST=your.staging.server.ip
STAGING_USER=deploy
